# Database
DATABASE_URL="postgresql://user:password@localhost:5435/game_api"

# Postgres — dùng cho Docker Compose
POSTGRES_USER=gameapi
POSTGRES_PASSWORD=change_me
POSTGRES_DB=game_api

# App
PORT=3001
NODE_ENV=development

# Frontend (dùng cho CORS)
FRONTEND_URL=http://localhost:3000

# JWT — đổi thành random string dài ít nhất 64 ký tự ở prod
JWT_SECRET=change_me_in_production_min_64_chars
JWT_REFRESH_SECRET=change_me_in_production_min_64_chars_refresh
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Email (Gmail SMTP — dùng App Password, không phải password thường)
MAIL_USER=your-gmail@gmail.com
MAIL_PASS=xxxx-xxxx-xxxx-xxxx
MAIL_FROM="Hacker Path <noreply@hacklab.dev>"

# Cloudinary (avatar storage)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
